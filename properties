import math

def calc_position_size(capital: float, risk_per_trade: float, entry: float, stop: float):
    risk_money = capital * risk_per_trade
    risk_per_share = abs(entry - stop)

    if risk_per_share <= 0:
        return 0

    qty = math.floor(risk_money / risk_per_share)
    return max(qty, 0)

