import pandas as pd

def detect_sweep(signal_row, prev_rows, lookback: int):
    recent = prev_rows.tail(lookback)
    prev_high = recent["high"].max()
    prev_low = recent["low"].min()

    if signal_row["high"] > prev_high:
        return {
            "direction": "SHORT",
            "sweep_price": signal_row["high"],
            "reference": prev_high
        }

    if signal_row["low"] < prev_low:
        return {
            "direction": "LONG",
            "sweep_price": signal_row["low"],
            "reference": prev_low
        }

    return None

