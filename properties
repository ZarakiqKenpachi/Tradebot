Вот упрощённый главный pipeline.

### Библиотеки:

import pandas as pd

### Код:

from config import StrategyConfig
from data.loader import load_1m_data
from data.resampler import resample_ohlcv
from strategy.signal_engine import find_setups
from strategy.retest import first_retest_exists
from execution.fills import limit_was_filled_on_1m
from execution.position import simulate_trade
from core.models import TradeResult
from logs.journal import save_results

def main():
    config = StrategyConfig()

    df_1m = load_1m_data("SBER_1m.txt")
    df_30m = resample_ohlcv(df_1m, "30T")
    df_1h = resample_ohlcv(df_1m, "1H")

    setups = find_setups(df_1h, config)
    results = []

    for setup in setups:
        retest_time = first_retest_exists(df_30m, setup, max_bars=4)
        if not retest_time:
            continue

        filled, fill_time = limit_was_filled_on_1m(df_1m, setup, retest_time, max_30m_bars=4)
        if not filled:
            continue

        result, exit_price, exit_time = simulate_trade(
            df_30m,
            setup,
            fill_time,
            timeout_bars=config.timeout_30m_bars
        )

        if result == "TP":
            r_multiple = config.rr
        elif result == "SL":
            r_multiple = -1.0
        else:
            risk = abs(setup.entry_price - setup.stop_price)
            pnl = exit_price - setup.entry_price if setup.direction == "LONG" else setup.entry_price - exit_price
            r_multiple = pnl / risk if risk > 0 else 0.0

        results.append(
            TradeResult(
                symbol=setup.symbol,
                direction=setup.direction,
                entry_time=fill_time,
                exit_time=exit_time,
                entry_price=setup.entry_price,
                exit_price=exit_price,
                result=result,
                r_multiple=r_multiple
            )
        )

    save_results(results)
    print(f"Готово. Сделок: {len(results)}")

if __name__ == "__main__":
    main()

