[24.03.2026 5:21] Дима: def candle_range(row) -> float:
    return row["high"] - row["low"]

def body_size(row) -> float:
    return abs(row["close"] - row["open"])

def body_ratio(row) -> float:
    rng = candle_range(row)
    if rng <= 0:
        return 0.0
    return body_size(row) / rng

def valid_displacement(row, direction: str, min_body_ratio: float) -> bool:
    ratio = body_ratio(row)

    if direction == "LONG":
        return row["close"] > row["open"] and ratio >= min_body_ratio

    if direction == "SHORT":
        return row["close"] < row["open"] and ratio >= min_body_ratio

    return False

