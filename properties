def build_entry_zone(signal_row, direction: str, zone_start: float, zone_end: float, entry_ratio: float):
    low = signal_row["low"]
    high = signal_row["high"]
    rng = high - low

    z1 = low + rng * zone_start
    z2 = low + rng * zone_end

    zone_low = min(z1, z2)
    zone_high = max(z1, z2)
    entry_price = low + rng * entry_ratio

    if direction == "LONG":
        stop_price = low
        take_price = None
    else:
        stop_price = high
        take_price = None

    return zone_low, zone_high, entry_price, stop_price

