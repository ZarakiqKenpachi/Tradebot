def resample_ohlcv(df: pd.DataFrame, tf: str) -> pd.DataFrame:
    temp = df.copy()
    temp = temp.set_index("datetime")

    out = temp.resample(tf).agg({
        "open": "first",
        "high": "max",
        "low": "min",
        "close": "last",
        "volume": "sum"
    }).dropna()

