from core.models import Setup
from strategy.sweep import detect_sweep
from strategy.displacement import valid_displacement
from strategy.zone import build_entry_zone

def find_setups(df_1h, config):
    setups = []

    for i in range(config.sweep_lookback, len(df_1h)):
        prev_rows = df_1h.iloc[:i]
        signal_row = df_1h.iloc[i]

        sweep = detect_sweep(signal_row, prev_rows, config.sweep_lookback)
        if not sweep:
            continue

        if not valid_displacement(signal_row, sweep["direction"], config.min_body_ratio):
            continue

        zone_low, zone_high, entry_price, stop_price = build_entry_zone(
            signal_row,
            sweep["direction"],
            config.zone_start,
            config.zone_end,
            config.entry_ratio
        )

        risk = abs(entry_price - stop_price)
        if risk <= 0:
            continue

        if sweep["direction"] == "LONG":
            take_price = entry_price + risk * config.rr
        else:
            take_price = entry_price - risk * config.rr

        setup = Setup(
            symbol=config.symbol,
            direction=sweep["direction"],
            signal_time=signal_row["datetime"],
            entry_price=entry_price,
            stop_price=stop_price,
            take_price=take_price,
            zone_low=zone_low,
            zone_high=zone_high,
            sweep_price=sweep["sweep_price"]
        )

        setups.append(setup)

    return setups

