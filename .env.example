# ================================================================
# TraderBot — шаблон переменных окружения
# Скопируйте в .env и заполните реальными значениями
# ================================================================

# Токен для загрузки рыночных данных (свечей)
TBANK_MARKET_TOKEN=your_market_data_token

# Торговые токены администраторов (соответствуют admin.tokens в config.yaml)
TBANK_ADMIN_TOKEN_1=your_admin_trading_token
# TBANK_ADMIN_TOKEN_2=your_second_admin_token

# Telegram chat_id каждого администратора (привязка к токену)
TELEGRAM_ADMIN_CHAT_ID_1=your_chat_id
# TELEGRAM_ADMIN_CHAT_ID_2=second_admin_chat_id

# Все chat_id администраторов через запятую (для broadcast-уведомлений)
TELEGRAM_ADMIN_CHAT_IDS=your_chat_id

# Telegram bot token (от @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token
