# T-Bank Invest API Tokens
# Get from: https://www.tbank.ru/invest/account/

# Sandbox token (for testing)
TBANK_SANDBOX_TOKEN=your_sandbox_token_here

# Live token (for real trading)
TBANK_LIVE_TOKEN=your_live_token_here

# Telegram Bot Token
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID
# Send a message to your bot, then get chat ID from:
# https://t.me/userinfobot
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
