# T-Bank Invest API Token
# Get from: https://www.tbank.ru/invest/account/
# For sandbox: use sandbox token from same account
TBANK_TOKEN=your_tbank_token_here

# Telegram Bot Token
# Get from: @BotFather on Telegram
# Create a bot and copy the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID
# Send a message to your bot, then get chat ID from bot logs or use:
# https://t.me/userinfobot
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
