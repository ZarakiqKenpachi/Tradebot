# TradingView credentials for Chart Analyzer
# Copy this file to passes_tv.env and fill in your values

# Method 1: Username + password (works for native TV accounts, NOT Google/Apple)
TV_USERNAME=
TV_PASSWORD=

# Method 2: Auth token from browser (works for ALL accounts including Google/Apple)
# Leave empty — Chart Analyzer will open Chrome for login and extract it automatically
TV_AUTH_TOKEN=
